<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/monthlyScreenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="17dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="تحلیل عملکرد  •  ماهانه"
                android:textColor="@color/white_72"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />

            <Button
                android:id="@+id/backButton"
                style="@style/ButtonGhost"
                android:layout_width="88dp"
                android:text="بازگشت" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="سوابق مابه‌التفاوت"
            android:textColor="@color/text_on_primary"
            android:textSize="25sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="مقایسهٔ مصرف واقعی و استاندارد، بر اساس ماه و محصول."
            android:textColor="@color/white_72"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="11dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="13dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_step_chip"
                    android:text="فیلتر"
                    android:textColor="@color/accent_dark"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="محدودهٔ گزارش"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView style="@style/TextLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ماه" />
                    <Spinner
                        android:id="@+id/filterYearSpinner" android:layout_width="wrap_content" android:layout_height="wrap_content"/><Spinner android:id="@+id/filterMonthSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_input"
                        android:popupBackground="@drawable/bg_dropdown" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.25"
                    android:orientation="vertical">
                    <TextView style="@style/TextLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="محصول" />
                    <AutoCompleteTextView
                        android:id="@+id/filterProductSearchEditText"
                        style="@style/InputField"
                        android:layout_height="48dp"
                        android:layout_marginTop="5dp"
                        android:hint="جستجو"
                        android:inputType="text"
                        android:popupBackground="@drawable/bg_dropdown" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/clearProductFilterButton"
                style="@style/ButtonSecondary"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:minHeight="42dp"
                android:layout_marginTop="9dp"
                android:text="نمایش همهٔ محصولات" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/monthlySummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:background="@drawable/bg_total_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="13dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/monthlyTotalStatusTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بدون محاسبه"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="جمع مابه‌التفاوت"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/monthlyTotalTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="۰ پا"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/monthlyScopeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="همه ماه‌ها • همه محصولات"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile" android:gravity="center_vertical"
                    android:orientation="vertical" android:paddingStart="9dp" android:paddingEnd="9dp">
                    <TextView android:id="@+id/visibleRecordsCountTextView" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="۰" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="رکورد" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>

                <View android:layout_width="7dp" android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile" android:gravity="center_vertical"
                    android:orientation="vertical" android:paddingStart="9dp" android:paddingEnd="9dp">
                    <TextView android:id="@+id/filteredActualTextView" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="۰ پا" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="واقعی" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>

                <View android:layout_width="7dp" android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile" android:gravity="center_vertical"
                    android:orientation="vertical" android:paddingStart="9dp" android:paddingEnd="9dp">
                    <TextView android:id="@+id/filteredExpectedTextView" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="۰ پا" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="استاندارد" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="47dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_badge_good" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp">
                    <TextView android:id="@+id/goodCutsCountTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="۰" android:textColor="@color/success_dark" android:textSize="16sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="7dp" android:text="برش خوب" android:textColor="@color/success_dark" android:textSize="10sp" />
                </LinearLayout>
                <View android:layout_width="8dp" android:layout_height="1dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_badge_bad" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp">
                    <TextView android:id="@+id/badCutsCountTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="۰" android:textColor="@color/danger_dark" android:textSize="16sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="7dp" android:text="برش بد" android:textColor="@color/danger_dark" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="9dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="جزئیات محاسبات"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="لمس طولانی برای حذف"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/emptyTextView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_empty_state"
                android:gravity="center"
                android:includeFontPadding="true"
                android:lineSpacingExtra="4dp"
                android:maxLines="2"
                android:padding="18dp"
                android:text="هنوز داده‌ای در این فیلتر ثبت نشده است.\nبعد از محاسبه، سوابق اینجا نمایش داده می‌شوند."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ListView
                android:id="@+id/recordsListView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="7dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:listSelector="@android:color/transparent"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/clearRecordsButton"
            style="@style/ButtonDanger"
            android:layout_width="match_parent"
            android:layout_marginTop="9dp"
            android:text="حذف همهٔ سوابق" />
    </LinearLayout>
</LinearLayout>
